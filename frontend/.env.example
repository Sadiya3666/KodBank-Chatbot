# API Configuration
REACT_APP_API_URL=http://localhost:5000/api

# Environment
REACT_APP_ENV=development

# Feature Flags
REACT_APP_ENABLE_DARK_MODE=false
REACT_APP_ENABLE_ANALYTICS=false

# Timeouts (in milliseconds)
REACT_APP_API_TIMEOUT=10000

# Refresh Intervals (in seconds)
REACT_APP_BALANCE_REFRESH_INTERVAL=30
REACT_APP_TRANSACTION_REFRESH_INTERVAL=60

# Currency Configuration
REACT_APP_DEFAULT_CURRENCY=INR
REACT_APP_CURRENCY_SYMBOL=₹

# Application Info
REACT_APP_NAME=KodBank
REACT_APP_VERSION=1.0.0
REACT_APP_DESCRIPTION=Modern Banking Solution

# Hugging Face Chatbot Configuration
# Replace with your actual Hugging Face token
REACT_APP_HF_TOKEN=your_huggingface_token_here



# Your Hugging Face Space URL
REACT_APP_HF_SPACE_URL=https://huggingface.co/spaces/SadiyaBanu/my-chatbot
